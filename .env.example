APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Umami analytics (https://umami.is) — script URL and site id from your Umami instance
UMAMI_ENABLED=true
UMAMI_SCRIPT_URL=https://analytics.radardelicitaciones.com/script.js
UMAMI_WEBSITE_ID=3a71e47e-8466-4078-b759-462a63b46135
# Optional: second Umami site id so admin panel traffic is separate from product
# UMAMI_ADMIN_WEBSITE_ID=
# UMAMI_ADMIN_ENABLED=true
# Optional: comma-separated hostnames for data-domains (Umami multi-domain)
# UMAMI_DOMAINS=

# Sentry (production: set SENTRY_LARAVEL_DSN on the server before config:cache runs)
SENTRY_LARAVEL_DSN=
# Optional: git SHA or version string for release tracking
# SENTRY_RELEASE=
# Optional: performance tracing sample rate 0.0–1.0 (omit to disable tracing)
# SENTRY_TRACES_SAMPLE_RATE=0.1
